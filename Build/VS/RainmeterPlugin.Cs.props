<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <!-- This is overridden by Build.ps1 during full build. -->
    <RmOutDirRoot Condition=" '$(Platform)' == 'x86' ">$(SolutionDir)BuildOut\$(Configuration)32\</RmOutDirRoot>
    <RmOutDirRoot Condition=" '$(Platform)' == 'x64' ">$(SolutionDir)BuildOut\$(Configuration)64\</RmOutDirRoot>
    <RmOutDirRoot Condition=" '$(Platform)' == 'ARM64' ">$(SolutionDir)BuildOut\$(Configuration)ARM\</RmOutDirRoot>

    <OutputPath>$(RmOutDirRoot)Plugins\</OutputPath>
  </PropertyGroup>
</Project>
